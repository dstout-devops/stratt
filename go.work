// Stratt multi-module workspace (ADR-0005).
//
// types/ — shared wire/domain types for the Named Kinds (charter §2), consumed by
//          the control plane today and stratt-agent when it lands (Phase 3).
// core/  — the Go control plane (charter §3): graph-store frontend, controllers,
//          dispatcher, compiler cadences, OpenAPI-first API.
go 1.26.0

use (
	./contracts
	./core
	./packs
	./plugins/ansible
	./plugins/ansibleproject
	./plugins/awsec2
	./plugins/awx
	./plugins/certissuer
	./plugins/chef
	./plugins/crossplane
	./plugins/declared
	./plugins/helm
	./plugins/kubecontainers
	./plugins/kubeservices
	./plugins/mcp
	./plugins/mesh
	./plugins/msgraph
	./plugins/netbox
	./plugins/notify
	./plugins/opentofu
	./plugins/puppet
	./plugins/salt
	./plugins/script
	./plugins/vcenter
	./sdk
	./sdk/secretbroker
	./types
)
