# EditorConfig — https://editorconfig.org  (extension is preinstalled in the devcontainer)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

[*.py]
indent_size = 4

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[{Taskfile.yml,Taskfile.yaml,*.yml,*.yaml}]
indent_size = 2
