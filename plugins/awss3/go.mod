// The AWS S3 Connector plugin (ADR-0046 Phase B / ADR-0097) — its own build/test/CI
// unit. It ships BOTH capabilities of the awss3 Connector: a metadata-only bucket
// Syncer (Observe bucket existence/config, NEVER object bytes — §1.2) and bucket
// lifecycle Actions (create/delete/enable-versioning/put-policy). It imports the lean
// plugin SDK and aws-sdk-go-v2, and NOTHING from core/ (the module-isolation discipline
// of ADR-0046). The s3 SDK is already vetted (dependency-scout 2026-07-13; used by
// core/internal/evidencestore) — no new dependency (§1.4).
module github.com/dstout-devops/stratt/plugins/awss3

go 1.25.0

require (
	github.com/aws/aws-sdk-go-v2 v1.42.1
	github.com/aws/aws-sdk-go-v2/config v1.32.29
	github.com/aws/aws-sdk-go-v2/service/s3 v1.105.0
	github.com/dstout-devops/stratt/sdk v0.0.0-00010101000000-000000000000
	google.golang.org/grpc v1.82.1
	google.golang.org/protobuf v1.36.12-0.20260120151049-f2248ac996af
)

require (
	github.com/aws/aws-sdk-go-v2/aws/protocol/eventstream v1.7.14 // indirect
	github.com/aws/aws-sdk-go-v2/credentials v1.19.28 // indirect
	github.com/aws/aws-sdk-go-v2/feature/ec2/imds v1.18.30 // indirect
	github.com/aws/aws-sdk-go-v2/internal/configsources v1.4.30 // indirect
	github.com/aws/aws-sdk-go-v2/internal/endpoints/v2 v2.7.30 // indirect
	github.com/aws/aws-sdk-go-v2/internal/v4a v1.4.31 // indirect
	github.com/aws/aws-sdk-go-v2/service/internal/accept-encoding v1.13.13 // indirect
	github.com/aws/aws-sdk-go-v2/service/internal/checksum v1.9.23 // indirect
	github.com/aws/aws-sdk-go-v2/service/internal/presigned-url v1.13.30 // indirect
	github.com/aws/aws-sdk-go-v2/service/internal/s3shared v1.19.31 // indirect
	github.com/aws/aws-sdk-go-v2/service/signin v1.4.0 // indirect
