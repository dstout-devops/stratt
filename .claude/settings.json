{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv:*)",
      "Bash(uvx:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pyright:*)",
      "Bash(pytest:*)",
      "Bash(node:*)",
      "Bash(npm run:*)",
      "Bash(npm ci)",
      "Bash(npm install:*)",
      "Bash(npm test:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(go:*)",
      "Bash(gofmt:*)",
      "Bash(task:*)",
      "Bash(psql:*)",
      "Bash(docker compose:*)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh repo view:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(which:*)",
      "Bash(find:*)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:modelcontextprotocol.io)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:go.dev)",
      "WebFetch(domain:docs.astral.sh)",
      "WebFetch(domain:docs.pydantic.dev)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:opentofu.org)",
      "WebFetch(domain:docs.temporal.io)",
      "WebFetch(domain:docs.nats.io)",
      "WebFetch(domain:www.postgresql.org)",
      "WebFetch(domain:openfga.dev)",
      "WebFetch(domain:kyverno.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(task --list)",
      "Bash(task setup:devcontainer)",
      "Bash(task ci *)",
      "Bash(task test *)",
      "Bash(bash -n .devcontainer/postCreateCommand.sh)",
      "Bash(node -e \"const fs=require\\('fs'\\);let s=fs.readFileSync\\('.devcontainer/devcontainer.json','utf8'\\);s=s.replace\\(/^\\\\s*\\\\/\\\\/.*$/gm,''\\);JSON.parse\\(s\\);console.log\\('devcontainer.json parses as valid JSON \\(comments stripped\\)'\\)\")",
      "Bash(gh auth *)",
      "Bash(command -v actionlint)",
      "Bash(actionlint .github/workflows/ci.yml)",
      "Bash(python3 -c \"import yaml,sys; yaml.safe_load\\(open\\('.github/workflows/ci.yml'\\)\\); print\\('ci.yml: valid YAML'\\)\")"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Read(./.devcontainer/.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/credentials)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Write(LICENSE)",
      "Edit(LICENSE)",
      "Write(stratt-charter.md)",
      "Edit(stratt-charter.md)",
      "Write(.git/**)",
      "Edit(.git/**)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh repo create:*)",
      "Bash(gh release:*)",
      "Bash(gh api:*)",
      "Bash(docker push:*)",
      "Bash(npm publish:*)",
      "Bash(uv publish:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-bash.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-paths.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/format-after-edit.sh",
            "timeout": 30,
            "statusMessage": "Formatting edited file…"
          }
        ]
      }
    ]
  }
}
